{
  "name": "howlflow",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@types/node": "^25.5.0",
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "dev:mobile": "turbo -F mobile dev",
    "dev:docs": "turbo -F docs dev",
    "ios": "turbo -F mobile ios",
    "ios:prod": "turbo -F mobile ios:prod",
    "prebuild": "turbo -F mobile prebuild",
    "prebuild:clean": "turbo -F mobile prebuild:clean",
    "docs:build": "turbo -F docs build"
  },
  "dependencies": {
    "@howlflow/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@howlflow/config": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.10"
}
